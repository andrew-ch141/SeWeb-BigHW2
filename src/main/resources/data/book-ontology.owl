<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:book="http://example.org/books#">

    <owl:Ontology rdf:about="http://example.org/books">
        <rdfs:comment>Ontology for a semantic book recommendation system.</rdfs:comment>
    </owl:Ontology>

    <owl:Class rdf:about="http://example.org/books#User"/>
    <owl:Class rdf:about="http://example.org/books#Book"/>
    <owl:Class rdf:about="http://example.org/books#Theme"/>
    <owl:Class rdf:about="http://example.org/books#ReadingLevel"/>
    <owl:Class rdf:about="http://example.org/books#Recommendation"/>

    <owl:ObjectProperty rdf:about="http://example.org/books#prefersTheme">
        <rdfs:domain rdf:resource="http://example.org/books#User"/>
        <rdfs:range rdf:resource="http://example.org/books#Theme"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/books#hasTheme">
        <rdfs:domain rdf:resource="http://example.org/books#Book"/>
        <rdfs:range rdf:resource="http://example.org/books#Theme"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/books#recommendedFor">
        <rdfs:domain rdf:resource="http://example.org/books#Recommendation"/>
        <rdfs:range rdf:resource="http://example.org/books#User"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/books#recommendsBook">
        <rdfs:domain rdf:resource="http://example.org/books#Recommendation"/>
        <rdfs:range rdf:resource="http://example.org/books#Book"/>
    </owl:ObjectProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/books#title">
        <rdfs:domain rdf:resource="http://example.org/books#Book"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/books#author">
        <rdfs:domain rdf:resource="http://example.org/books#Book"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/books#readingLevel">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <book:Theme rdf:about="http://example.org/books#ScienceFiction">
        <rdfs:label>Science Fiction</rdfs:label>
    </book:Theme>
    <book:Theme rdf:about="http://example.org/books#Fantasy">
        <rdfs:label>Fantasy</rdfs:label>
    </book:Theme>
    <book:Theme rdf:about="http://example.org/books#Mystery">
        <rdfs:label>Mystery</rdfs:label>
    </book:Theme>
    <book:Theme rdf:about="http://example.org/books#Murder">
        <rdfs:label>Murder</rdfs:label>
    </book:Theme>

    <book:User rdf:about="http://example.org/books#Alice">
        <rdfs:label>Alice</rdfs:label>
        <book:readingLevel>Intermediate</book:readingLevel>
        <book:prefersTheme rdf:resource="http://example.org/books#ScienceFiction"/>
    </book:User>

    <book:User rdf:about="http://example.org/books#Bob">
        <rdfs:label>Bob</rdfs:label>
        <book:readingLevel>Beginner</book:readingLevel>
        <book:prefersTheme rdf:resource="http://example.org/books#Mystery"/>
    </book:User>

    <book:Book rdf:about="http://example.org/books#Dune">
        <book:title>Dune</book:title>
        <book:author>Frank Herbert</book:author>
        <book:readingLevel>Advanced</book:readingLevel>
        <book:hasTheme rdf:resource="http://example.org/books#ScienceFiction"/>
        <book:hasTheme rdf:resource="http://example.org/books#Fantasy"/>
    </book:Book>

    <book:Book rdf:about="http://example.org/books#TheSilentPatient">
        <book:title>The Silent Patient</book:title>
        <book:author>Alex Michaelides</book:author>
        <book:readingLevel>Intermediate</book:readingLevel>
        <book:hasTheme rdf:resource="http://example.org/books#Mystery"/>
        <book:hasTheme rdf:resource="http://example.org/books#Murder"/>
    </book:Book>

    <book:Book rdf:about="http://example.org/books#HungerGames">
        <book:title>Hunger Games</book:title>
        <book:author>Suzanne Collins</book:author>
        <book:readingLevel>Beginner</book:readingLevel>
        <book:hasTheme rdf:resource="http://example.org/books#ScienceFiction"/>
        <book:hasTheme rdf:resource="http://example.org/books#Fantasy"/>
    </book:Book>
</rdf:RDF>
